{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "npm run start:lan",
    "start:tunnel": "expo start --tunnel",
    "start:lan": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ip=(Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.IPAddress -match '^(192\\.168|10\\.|172\\.(1[6-9]|2[0-9]|3[0-1])\\.)' -and $_.InterfaceAlias -match 'Wi-Fi|Wireless|WLAN|Ethernet' } | Sort-Object -Property InterfaceMetric | Select-Object -First 1 -ExpandProperty IPAddress); if (-not $ip) { throw 'No reachable private LAN IP found. Connect to Wi-Fi and retry.' }; $env:REACT_NATIVE_PACKAGER_HOSTNAME=$ip; npx expo start --lan --port 8083 --clear\"",
    "start:offline": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ip=(Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.IPAddress -match '^(192\\.168|10\\.|172\\.(1[6-9]|2[0-9]|3[0-1])\\.)' -and $_.InterfaceAlias -match 'Wi-Fi|Wireless|WLAN|Ethernet' } | Sort-Object -Property InterfaceMetric | Select-Object -First 1 -ExpandProperty IPAddress); if (-not $ip) { throw 'No reachable private LAN IP found. Connect to Wi-Fi and retry.' }; $env:REACT_NATIVE_PACKAGER_HOSTNAME=$ip; npx expo start --offline --port 8083\"",
    "android": "expo start --android --host lan",
    "ios": "expo start --ios --host lan",
    "web": "expo start --web --host lan",
    "dev": "expo start --host lan",
    "build": "expo export --platform web",
    "build:dev": "expo export --platform web --clear",
    "lint": "eslint .",
    "preview": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest"
  },
